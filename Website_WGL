      { platz: 7,  nachname: "Merz",    vorname: "Maximilian", ort: "Grimmelfingen" },
      { platz: 8,  nachname: "Weiss",   vorname: "Jonas",      ort: "Grimmelfingen" },
      { platz: 9,  nachname: "Seiwert", vorname: "Tim",        ort: "Lindenhöhe" },
      { platz: 10, nachname: "Fromm",   vorname: "Dominic",    ort: "Lindenhöhe" },
      { platz: 11, nachname: "Weiss",   vorname: "Daniel",     ort: "Grimmelfingen" },
      { platz: 12, nachname: "Gross",   vorname: "Maximilian", ort: "Grimmelfingen" },
      { platz: 13, nachname: "Preiß",   vorname: "Nils",       ort: "Grimmelfingen" }
    ];

    function getInitials(v, n) { return (v.charAt(0) + n.charAt(0)).toUpperCase(); }

    function getCountdown() {
      const election = new Date('2026-07-05T08:00:00');
      const now = new Date();
      const diff = election - now;
      if (diff <= 0) return { tage: 0, stunden: 0, minuten: 0, vorbei: true };
      return {
        tage: Math.floor(diff / (1000*60*60*24)),
        stunden: Math.floor((diff % (1000*60*60*24)) / (1000*60*60)),
        minuten: Math.floor((diff % (1000*60*60)) / (1000*60)),
        vorbei: false
      };
    }

    const pages = {

      'startseite': () => {
        const cd = getCountdown();
        const countdownHTML = cd.vorbei
          ? '<p style="font-size:1.2rem;font-weight:600;color:var(--accent-light);">Die Wahl hat stattgefunden!</p>'
          : '<div class="countdown-row">' +
            '<div class="countdown-box"><span class="num" id="cd-tage">' + cd.tage + '</span><span class="label">Tage</span></div>' +
            '<div class="countdown-box"><span class="num" id="cd-stunden">' + cd.stunden + '</span><span class="label">Stunden</span></div>' +
            '<div class="countdown-box"><span class="num" id="cd-minuten">' + cd.minuten + '</span><span class="label">Minuten</span></div>' +
            '</div>';
        return '<section class="hero"><div class="hero-content container">' +
          '<h1>JugendGL</h1>' +
          '<div class="slogan">5. Juli 2026 &ndash; Eine Stimme für die Jugend!</div>' +
          '<p class="subtitle">Wählervereinigung für den Ortschaftsrat Grimmelfingen-Lindenhöhe.<br>Die erste Ortschaftsratswahl in der Geschichte unserer Ortschaft.</p>' +
