  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --primary: #1a3a5c;
      --primary-light: #2a5a8c;
      --primary-dark: #0f2440;
      --accent: #b8860b;
      --accent-light: #d4a017;
      --cta-red: #c0392b;
      --cta-red-light: #e74c3c;
      --text: #2c2c2c;
      --text-light: #5a5a5a;
      --bg: #f8f6f2;
      --bg-white: #ffffff;
      --bg-light: #eee9e0;
      --border: #d4cfc6;
      --shadow: rgba(0,0,0,0.08);
      --font-heading: 'Georgia','Times New Roman',serif;
      --font-body: 'Segoe UI','Helvetica Neue',Arial,sans-serif;
    }
    html { scroll-behavior: smooth; font-size: 16px; }
    body { font-family: var(--font-body); color: var(--text); background: var(--bg); line-height: 1.7; min-height: 100vh; display: flex; flex-direction: column; }
    a { color: var(--primary); text-decoration: none; transition: color .2s; }
    a:hover { color: var(--accent); }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

    /* === Election Banner === */
    .election-banner { background: linear-gradient(90deg, var(--cta-red) 0%, #a93226 100%); color: #fff; padding: 10px 0; text-align: center; font-weight: 600; font-size: .95rem; letter-spacing: .03em; cursor: pointer; transition: background .2s; }
    .election-banner:hover { background: linear-gradient(90deg, var(--cta-red-light) 0%, var(--cta-red) 100%); }
    .election-banner .date-badge { display: inline-block; background: #fff; color: var(--cta-red); padding: 2px 12px; border-radius: 20px; font-weight: 700; margin-right: 10px; font-size: .88rem; }

    /* === Top Bar === */
    .top-bar { background: var(--primary-dark); color: rgba(255,255,255,.7); font-size: .85rem; padding: 6px 0; }
    .top-bar .container { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 6px; }
    .top-bar a { color: rgba(255,255,255,.8); }
    .top-bar a:hover { color: #fff; }

    /* === Header === */
    .site-header { background: var(--primary); color: #fff; box-shadow: 0 2px 8px var(--shadow); position: sticky; top: 0; z-index: 100; }
    .header-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 24px; max-width: 1100px; margin: 0 auto; }
    .site-logo { display: flex; align-items: center; gap: 14px; padding: 14px 0; cursor: pointer; }
    .logo-icon { width: 50px; height: 50px; background: var(--accent); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; font-weight: bold; color: #fff; font-family: var(--font-heading); flex-shrink: 0; }
    .site-title { font-family: var(--font-heading); font-size: 1.15rem; font-weight: normal; line-height: 1.3; }
    .site-title strong { display: block; font-size: 1.05rem; }

    /* === Nav === */
    .main-nav ul { display: flex; list-style: none; }
    .main-nav a { display: block; color: rgba(255,255,255,.85); padding: 22px 14px; font-size: .9rem; font-weight: 500; border-bottom: 3px solid transparent; transition: all .2s; cursor: pointer; }
    .main-nav a:hover, .main-nav a.active { color: #fff; border-bottom-color: var(--accent); background: rgba(255,255,255,.05); }
    .menu-toggle { display: none; background: none; border: none; color: #fff; font-size: 1.6rem; cursor: pointer; padding: 10px; }

    /* === Hero === */
    .hero { background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); color: #fff; padding: 60px 0 50px; text-align: center; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; inset: 0; background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); }
    .hero-content { position: relative; z-index: 1; }
    .hero h1 { font-family: var(--font-heading); font-size: 2.6rem; font-weight: normal; margin-bottom: 10px; }
    .hero .slogan { font-size: 1.35rem; font-weight: 600; color: var(--accent-light); margin-bottom: 18px; letter-spacing: .04em; }
    .hero .subtitle { font-size: 1.1rem; opacity: .9; margin-bottom: 28px; max-width: 650px; margin-left: auto; margin-right: auto; }

    /* Countdown */
    .countdown-row { display: flex; justify-content: center; gap: 20px; margin-bottom: 30px; flex-wrap: wrap; }
    .countdown-box { background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.15); border-radius: 8px; padding: 14px 20px; min-width: 80px; text-align: center; }
    .countdown-box .num { font-size: 2rem; font-weight: 700; display: block; line-height: 1.2; }
    .countdown-box .label { font-size: .75rem; text-transform: uppercase; letter-spacing: .08em; opacity: .8; }

    .cta-btn { display: inline-block; background: var(--accent); color: #fff; padding: 14px 36px; font-size: 1rem; font-weight: 600; border-radius: 4px; transition: background .2s, transform .2s; cursor: pointer; border: none; }
    .cta-btn:hover { background: var(--accent-light); color: #fff; transform: translateY(-1px); }
    .cta-btn-red { background: var(--cta-red); }
    .cta-btn-red:hover { background: var(--cta-red-light); }

    /* === Page Header === */
    .page-header { background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: #fff; padding: 45px 0; text-align: center; }
    .page-header h1 { font-family: var(--font-heading); font-size: 2.2rem; font-weight: normal; margin-bottom: 8px; }
    .page-header .breadcrumb { font-size: .9rem; opacity: .8; }
    .page-header .breadcrumb a { color: rgba(255,255,255,.8); cursor: pointer; }

    /* === Main === */
    .main-content { flex: 1; padding: 50px 0; }
    .content-section { margin-bottom: 50px; }
    .content-section h2 { font-family: var(--font-heading); font-size: 1.8rem; color: var(--primary); margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid var(--accent); display: inline-block; }
    .content-section h3 { font-family: var(--font-heading); font-size: 1.3rem; color: var(--primary); margin-bottom: 12px; }
    .content-section p { margin-bottom: 16px; }

    /* === Election Info Box === */
    .election-info-box { background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: #fff; border-radius: 8px; padding: 36px; margin: 30px 0; text-align: center; }
    .election-info-box h3 { color: #fff; font-family: var(--font-heading); font-size: 1.4rem; margin-bottom: 6px; }
    .election-info-box .big-date { font-size: 2.2rem; font-weight: 700; color: var(--accent-light); margin: 10px 0; }
    .election-info-box p { color: rgba(255,255,255,.9); margin-bottom: 10px; }

    /* === Wahlinfo Grid === */
    .wahlinfo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 24px; }
    .wahlinfo-card { background: var(--bg-white); border: 1px solid var(--border); border-top: 3px solid var(--primary); border-radius: 6px; padding: 24px; }
    .wahlinfo-card h3 { font-family: var(--font-heading); color: var(--primary); font-size: 1.05rem; margin-bottom: 10px; }
    .wahlinfo-card p { color: var(--text-light); font-size: .93rem; margin-bottom: 8px; }
    .wahlinfo-card strong { color: var(--text); }

    /* === Features === */
    .features { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 30px; }
    .feature-box { background: var(--bg-white); border: 1px solid var(--border); border-radius: 6px; padding: 30px 24px; text-align: center; transition: box-shadow .3s; }
    .feature-box:hover { box-shadow: 0 4px 16px var(--shadow); }
    .feature-icon { font-size: 2.5rem; margin-bottom: 16px; display: block; }
    .feature-box h3 { font-family: var(--font-heading); color: var(--primary); margin-bottom: 10px; font-size: 1.1rem; }
    .feature-box p { color: var(--text-light); font-size: .93rem; }

    /* === Kandidaten === */
    .kandidaten-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 28px; margin-top: 24px; }
    .kandidat-card { background: var(--bg-white); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; text-align: center; transition: box-shadow .3s, transform .2s; }
    .kandidat-card:hover { box-shadow: 0 6px 20px var(--shadow); transform: translateY(-2px); }
    .kandidat-photo { width: 100%; height: 220px; background: linear-gradient(135deg, var(--bg-light) 0%, var(--border) 100%); display: flex; align-items: center; justify-content: center; font-size: 3.5rem; color: var(--primary-light); }
    .kandidat-info { padding: 20px; }
    .kandidat-info h3 { font-family: var(--font-heading); color: var(--primary); font-size: 1.1rem; margin-bottom: 4px; }
    .kandidat-info .rolle { color: var(--accent); font-size: .85rem; font-weight: 600; margin-bottom: 4px; }
    .kandidat-info .ort { color: var(--text-light); font-size: .85rem; margin-bottom: 8px; font-style: italic; }
    .kandidat-info .platz { background: var(--primary); color: #fff; display: inline-block; padding: 2px 12px; border-radius: 12px; font-size: .78rem; font-weight: 600; margin-bottom: 8px; }

    /* === Programm === */
    .programm-list { list-style: none; margin-top: 20px; }
    .programm-item { background: var(--bg-white); border: 1px solid var(--border); border-left: 4px solid var(--accent); border-radius: 0 6px 6px 0; padding: 24px 28px; margin-bottom: 18px; transition: box-shadow .2s; }
    .programm-item:hover { box-shadow: 0 2px 12px var(--shadow); }
    .programm-item h3 { font-family: var(--font-heading); color: var(--primary); margin-bottom: 8px; font-size: 1.15rem; }
    .programm-item .nummer { display: inline-block; background: var(--primary); color: #fff; width: 30px; height: 30px; border-radius: 50%; text-align: center; line-height: 30px; font-size: .85rem; font-weight: 700; margin-right: 10px; vertical-align: middle; }
    .programm-item p { color: var(--text-light); font-size: .95rem; }

    /* === News === */
    .news-list { margin-top: 24px; }
    .news-item { background: var(--bg-white); border: 1px solid var(--border); border-radius: 6px; padding: 28px; margin-bottom: 22px; transition: box-shadow .2s; }
    .news-item:hover { box-shadow: 0 2px 12px var(--shadow); }
    .news-date { font-size: .82rem; color: var(--accent); font-weight: 600; margin-bottom: 6px; text-transform: uppercase; letter-spacing: .05em; }
    .news-item h3 { font-family: var(--font-heading); color: var(--primary); margin-bottom: 10px; font-size: 1.2rem; }
    .news-item p { color: var(--text-light); font-size: .95rem; }

    /* === Kontakt === */
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 24px; }
    .contact-form label { display: block; font-weight: 600; margin-bottom: 6px; font-size: .92rem; }
    .contact-form input, .contact-form textarea { width: 100%; padding: 12px 14px; border: 1px solid var(--border); border-radius: 4px; font-family: var(--font-body); font-size: .95rem; margin-bottom: 18px; background: var(--bg-white); transition: border-color .2s; }
    .contact-form input:focus, .contact-form textarea:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(26,58,92,.1); }
    .contact-form textarea { min-height: 140px; resize: vertical; }
    .btn-submit { display: inline-block; background: var(--primary); color: #fff; padding: 13px 32px; font-size: 1rem; font-weight: 600; border: none; border-radius: 4px; cursor: pointer; transition: background .2s; font-family: var(--font-body); }
    .btn-submit:hover { background: var(--primary-light); }
    .contact-info-box { background: var(--bg-white); border: 1px solid var(--border); border-radius: 6px; padding: 28px; margin-bottom: 22px; }
    .contact-info-box h3 { font-family: var(--font-heading); color: var(--primary); margin-bottom: 16px; }
    .contact-detail { display: flex; gap: 12px; margin-bottom: 18px; align-items: flex-start; }
    .contact-detail .icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 2px; }
    .contact-detail p { font-size: .95rem; line-height: 1.5; }

    /* === Legal === */
    .legal-content { max-width: 800px; }
    .legal-content h3 { margin-top: 28px; margin-bottom: 10px; font-family: var(--font-heading); color: var(--primary); font-size: 1.15rem; }
    .legal-content p { color: var(--text); font-size: .95rem; margin-bottom: 12px; }
    .legal-content ul { margin: 0 0 16px 24px; color: var(--text); font-size: .95rem; }
    .legal-content li { margin-bottom: 6px; }

    /* === Footer === */
    .site-footer { background: var(--primary-dark); color: rgba(255,255,255,.75); padding: 40px 0 0; margin-top: auto; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 40px; padding-bottom: 30px; }
    .footer-col h4 { color: #fff; font-family: var(--font-heading); font-size: 1rem; margin-bottom: 14px; }
    .footer-col p { font-size: .9rem; line-height: 1.6; margin-bottom: 8px; }
    .footer-col ul { list-style: none; }
    .footer-col li { margin-bottom: 8px; }
    .footer-col a { color: rgba(255,255,255,.7); font-size: .9rem; cursor: pointer; }
    .footer-col a:hover { color: var(--accent-light); }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,.1); padding: 18px 0; text-align: center; font-size: .82rem; color: rgba(255,255,255,.5); }
    .footer-legal a { margin: 0 8px; color: rgba(255,255,255,.5); cursor: pointer; }
    .footer-legal a:hover { color: var(--accent-light); }

    /* === Fade === */
    .fade-in { opacity: 0; transform: translateY(20px); transition: opacity .5s ease, transform .5s ease; }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    /* === Responsive === */
    @media (max-width: 900px) {
      .features, .wahlinfo-grid { grid-template-columns: 1fr; }
      .contact-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr; gap: 24px; }
    }
    @media (max-width: 768px) {
      .header-inner { flex-wrap: wrap; }
      .menu-toggle { display: block; }
      .main-nav { display: none; width: 100%; order: 3; }
      .main-nav.open { display: block; }
      .main-nav ul { flex-direction: column; }
      .main-nav a { padding: 14px 18px; border-bottom: 1px solid rgba(255,255,255,.1); }
      .hero h1 { font-size: 1.8rem; }
      .hero .slogan { font-size: 1.1rem; }
      .hero { padding: 40px 0 35px; }
      .page-header h1 { font-size: 1.6rem; }
      .kandidaten-grid { grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); }
      .top-bar { display: none; }
      .countdown-box { min-width: 65px; padding: 10px 14px; }
      .countdown-box .num { font-size: 1.5rem; }
    }
  </style>
</head>
