    // --- Navigation ---
    let currentPage = 'startseite';
    let countdownInterval = null;

    function navigate(page) {
      if (!pages[page]) return;
      currentPage = page;
      document.getElementById('app').innerHTML = pages[page]();

      document.querySelectorAll('.main-nav a').forEach(function(a) { a.classList.remove('active'); });
      const nav = document.getElementById('nav-' + page);
      if (nav) nav.classList.add('active');

      window.scrollTo({ top: 0, behavior: 'smooth' });
      document.getElementById('mainNav').classList.remove('open');

      setTimeout(function() {
        document.querySelectorAll('.fade-in').forEach(function(el, i) {
          setTimeout(function() { el.classList.add('visible'); }, i * 100);
        });
      }, 50);

      history.pushState(null, '', '#' + page);

      if (countdownInterval) { clearInterval(countdownInterval); countdownInterval = null; }
      if (page === 'startseite') {
        countdownInterval = setInterval(function() {
          var cd = getCountdown();
          var t = document.getElementById('cd-tage');
          var s = document.getElementById('cd-stunden');
          var m = document.getElementById('cd-minuten');
          if (t) t.textContent = cd.tage;
          if (s) s.textContent = cd.stunden;
          if (m) m.textContent = cd.minuten;
        }, 60000);
      }
    }

    function toggleMenu() { document.getElementById('mainNav').classList.toggle('open'); }

    function handleContactForm(e) {
      e.preventDefault();
      var name = document.getElementById('name').value;
      var email = document.getElementById('email').value;
      var betreff = document.getElementById('betreff').value;
      var nachricht = document.getElementById('nachricht').value;
      var subject = encodeURIComponent(betreff || 'Nachricht über JugendGL Website');
      var body = encodeURIComponent('Name: ' + name + '\nE-Mail: ' + email + '\n\n' + nachricht);
      window.location.href = 'mailto:JugendGL-Ulm@outlook.com?subject=' + subject + '&body=' + body;
    }

    window.addEventListener('hashchange', function() {
      var p = location.hash.replace('#','') || 'startseite';
      if (pages[p]) navigate(p);
    });

    navigate(location.hash.replace('#','') || 'startseite');
  </script>
