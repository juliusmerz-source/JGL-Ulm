    const kandidaten = [
      { platz: 1,  nachname: "Hauff",   vorname: "Christin",   ort: "Grimmelfingen" },
      { platz: 2,  nachname: "Merz",    vorname: "Julius",     ort: "Grimmelfingen", rolle: "Hauptansprechpartner" },
